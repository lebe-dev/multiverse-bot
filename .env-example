TELEGRAM_BOT_TOKEN=CHANGE-ME
LOG_LEVEL=info
ALLOWED_USERS=user1,user2
ADMIN_USERS=admin1,admin2
COBALT_API_URL=http://cobalt:9000  # when running via docker-compose; use https://api.cobalt.tools for standalone runs
YTDLP_PATH=yt-dlp                 # path to yt-dlp executable
YTDLP_COOKIES_FILE=./cookies.txt  # path to cookies file for YouTube auth
THREADS_ENGINE=default            # threads download engine: "default" (direct scraping) or "lovethreads" (lovethreads.net proxy)
YOUTUBE_ENGINE=default            # youtube download engine: "default" (yt-dlp) or "savevids" (vidssave.com API)
