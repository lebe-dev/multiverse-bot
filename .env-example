TELEGRAM_BOT_TOKEN=CHANGE-ME

# Local Telegram Bot API — only needed if you want to send files > 50 MB.
# Get these from https://my.telegram.org (API development tools).
# TELEGRAM_API_ID=CHANGE-ME
# TELEGRAM_API_HASH=CHANGE-ME

ADMIN_USERS=admin1
ALLOWED_USERS=user1,user2      # leave empty to allow everyone
LOG_LEVEL=info
DEBUG=false                    # verbose error details for admin chats

# Video processing
TG_LIMIT=50                    # standard Telegram file size limit (MB)

# Local Telegram Bot API — enables sending files up to 2 GB
# Only takes effect if TELEGRAM_API_ID/HASH are set and the service is running.
# LOCAL_BOT_API_URL=http://telegram-bot-api:8081

# Downloaders
YTDLP_PATH=yt-dlp
COBALT_API_URL=http://cobalt:9000
THREADS_ENGINE=default         # "default" (direct) or "lovethreads"
YOUTUBE_ENGINE=default         # "default" (yt-dlp) or "savevids"

# YouTube watcher
WATCH_POLL_INTERVAL=15m        # how often to check channels for new videos
WATCH_MAX_SUBSCRIPTIONS=20     # max subscriptions per user
WATCH_MAX_CHANNELS_TOTAL=100   # global cap on unique tracked channels
WATCH_AUTO_DOWNLOAD=false      # true = send video file immediately, false = send notification with Download button
SQLITE_PATH=./data/bot.db     # SQLite database path (use /data/bot.db in Docker)

# Instagram (all features disabled by default)
INSTAGRAM_FEATURES_ENABLED=false  # true = enable Instagram download, watchers, cookies
WATCH_INSTAGRAM_POLL_INTERVAL=24h  # how often to check for new stories
WATCH_INSTAGRAM_POSTS_POLL_INTERVAL=24h  # how often to check for new posts

# Google Drive — per-user OAuth2 via Device Flow
# Create an OAuth 2.0 client in Google Cloud Console:
#   Type: "TVs and Limited Input devices" (no redirect URI required)
#   Enable: Google Drive API
# Users authenticate with /auth — files go to their own Drive (drive.file scope only)
# GOOGLE_CLIENT_ID=CHANGE-ME
# GOOGLE_CLIENT_SECRET=CHANGE-ME

# Plugins — external HTTP services extending bot functionality
# See plugins.yml.example for config format
# PLUGINS_CONFIG=./plugins.yml

# Storage paths (optional — defaults shown)
# SETTINGS_FILE=./user_settings.json
# DRIVE_TOKENS_FILE=./user_drive_tokens.json
# ADMIN_CHATS_FILE=./data/admin_chats.json

# Sentry error reporting — only error events (stack traces) are sent, no tracing.
# Leave SENTRY_DSN empty to disable.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
