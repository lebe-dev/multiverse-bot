TELEGRAM_BOT_TOKEN=CHANGE-ME
TELEGRAM_API_ID=CHANGE-ME
TELEGRAM_API_HASH=CHANGE-ME

ADMIN_USERS=admin1
ALLOWED_USERS=user1,user2      # leave empty to allow everyone
LOG_LEVEL=info

# Video processing
TG_LIMIT=50                    # standard Telegram file size limit (MB)
MIN_QUALITY=720p               # compression target when file > TG_LIMIT

# Local Telegram Bot API — enables sending files up to 2 GB
LOCAL_BOT_API_URL=http://telegram-bot-api:8081

# Downloaders
YTDLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
YTDLP_COOKIES_FILE=./cookies.txt
COBALT_API_URL=http://cobalt:9000
THREADS_ENGINE=default         # "default" (direct) or "lovethreads"
YOUTUBE_ENGINE=default         # "default" (yt-dlp) or "savevids"

# Google Drive — service account (shared folder, optional)
# GDRIVE_KEY_FILE=./gdrive-key.json
# GDRIVE_FOLDER_ID=              # Google Drive folder ID

# Google Drive — per-user OAuth2 via Device Flow (recommended)
# Create an OAuth 2.0 client in Google Cloud Console:
#   Type: "TVs and Limited Input devices" (no redirect URI required)
#   Enable: Google Drive API
# Users authenticate with /auth — files go to their own Drive (drive.file scope only)
# GOOGLE_CLIENT_ID=CHANGE-ME
# GOOGLE_CLIENT_SECRET=CHANGE-ME
